#include "monokey.dtsi"

/* 既存のキーマトリクスを削除 */
/delete-node/ &kscan0;

/ {
    chosen {
        zmk,kscan = &kscan_dummy;
    };

    /* * 【ゼロ割り回避 ＆ 参照エラー回避の無敵ダミー】
     * 1. columns と rows を 1 にして起動時のパニック（即死）を防ぐ
     * 2. kscan と kscan0 の両方の名前を名乗ることで、dtsiからのエラーを全て吸収する
     */
    kscan: kscan0: kscan_dummy {
        compatible = "zmk,kscan-mock";
        columns = <1>;
        rows = <1>;
        events = <0>;
    };
};
