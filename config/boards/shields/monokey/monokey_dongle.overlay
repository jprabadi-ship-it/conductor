#include "monokey.dtsi"

/* 既存のキーマトリクスを削除 */
/delete-node/ &kscan0;

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    /* * 【はみ出しパニック回避の広大なダミー】
     * 1x1だと座標エラーで自爆するため、
     * どんなキーボードでも収まる 16x16 の十分な枠を用意します。
     */
    kscan: kscan0: kscan_mock_node {
        compatible = "zmk,kscan-mock";
        columns = <16>;
        rows = <16>;
        events = <0>;
    };
};
