/ {
    /* キーボードとしての機能をすべて無効化し、LEDだけを定義する */
    chosen {
        /delete-property/ zmk,kscan;
        /delete-property/ zmk,matrix_transform;
    };

    leds {
        compatible = "gpio-leds";
        blue_led: led_0 {
            gpios = <&gpio0 26 GPIO_ACTIVE_LOW>;
            label = "Blue LED";
        };
    };
};
