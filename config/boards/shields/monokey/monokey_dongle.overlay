#include "monokey.dtsi"

/* 一旦本物の kscan0 を消去する */
/delete-node/ &kscan0;

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    /* ZMK Studioが探せるように、同じ kscan0 という名前でダミーを再定義する */
    kscan0: kscan_dummy {
        compatible = "zmk,kscan-mock";
        columns = <0>;
        rows = <0>;
        events = <0>;
    };
};
