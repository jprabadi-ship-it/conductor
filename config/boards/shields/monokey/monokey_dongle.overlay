#include "monokey.dtsi"

/* 既存のキーマトリクスを削除 */
/delete-node/ &kscan0;

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    /* * 【ゼロ割り回避 ＆ 参照エラー回避の無敵ダミー】
     * kscan と kscan0 という2つの「ラベル」を持たせつつ、
     * ノード名を kscan_mock_node として定義します。
     */
    kscan: kscan0: kscan_mock_node {
        compatible = "zmk,kscan-mock";
        columns = <1>;
        rows = <1>;
        events = <0>;
    };
};
