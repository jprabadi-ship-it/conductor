/ { zmk,compat-check = "skip"; };

#include "monokey.dtsi"
#include <dt-bindings/pinctrl/nrf-pinctrl.h>
#include <dt-bindings/input/input-event-codes.h>
/* 🌟 これが抜けていました！ Y軸反転（INPUT_TRANSFORM_Y_INVERT）を翻訳する辞書 */
#include <dt-bindings/zmk/input_transform.h> 
#include <input/processors.dtsi> 

/* 右ユニットのオフセット (公式通り6) */
&default_transform { col-offset = <6>; };

/* NFCピンをGPIOとして解放 */
&uicr { nfct-pins-as-gpios; };
&xiao_serial { status = "disabled"; };

&pinctrl {
    pwm0_default: pwm0_default {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 26)>, <NRF_PSEL(PWM_OUT1, 0, 30)>;
            nordic,drive-mode = <NRF_DRIVE_S0S1>;
        };
    };
    pwm0_sleep: pwm0_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 26)>, <NRF_PSEL(PWM_OUT1, 0, 30)>;
            low-power-enable;
        };
    };

    /* 3線式SPI (D4ピンでMOSI/MISO共有) */
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,  /* D5 */
                    <NRF_PSEL(SPIM_MOSI, 0, 4)>, /* D4 */
                    <NRF_PSEL(SPIM_MISO, 0, 4)>; /* D4 */
        };
    };
    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                    <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};

&pwm0 {
    status = "okay";
    pinctrl-0 = <&pwm0_default>;
    pinctrl-1 = <&pwm0_sleep>;
    pinctrl-names = "default", "sleep";
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>; /* P0.09 */

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610"; 
        reg = <0>;
        spi-max-frequency = <2000000>;
        motion-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; /* D0 */
        zephyr,axis-x = <INPUT_REL_X>;
        zephyr,axis-y = <INPUT_REL_Y>;
        res-cpi = <800>; 
    };
};

/ {
    kscan0: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";

        /* 5列構成 */
        col-gpios
            = <&xiao_d 10 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 8 GPIO_ACTIVE_HIGH> 
            , <&xiao_d 7 GPIO_ACTIVE_HIGH> 
            , <&gpio0 10 GPIO_ACTIVE_HIGH> 
            ;

        row-gpios
            = <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 
            , <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 
            ;
    };

    backlight: pwmleds {
        compatible = "pwm-leds";
        status = "okay";
        led_red { pwms = <&pwm0 0 10000000 PWM_POLARITY_INVERTED>; };
        led_green { pwms = <&pwm0 1 10000000 PWM_POLARITY_INVERTED>; };
    };

    vbatt: vbatt { compatible = "zmk,battery-nrf-vddh"; };

    chosen {
        zmk,kscan = &kscan0;
        zmk,backlight = &backlight;
        zmk,battery = &vbatt;
        zmk,split-peripheral = &trackball_split; 
    };

    split_inputs {
        compatible = "zmk,split-inputs";
        #address-cells = <1>;
        #size-cells = <0>;
        trackball_split: trackball@0 {
            compatible = "zmk,input-split";
            reg = <0>;
            device = <&trackball>;
        };
    };

    chg_stat: chg_stat { status = "disabled"; };
};